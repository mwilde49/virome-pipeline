Bootstrap: docker
From: ubuntu:22.04

%labels
    tool    Kraken2
    version 2.1.3
    purpose Taxonomic classification of host-depleted reads against viral database

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        wget \
        build-essential \
        zlib1g-dev \
        libstdc++6 \
        rsync \
        perl \
        && rm -rf /var/lib/apt/lists/*

    cd /opt
    wget -q https://github.com/DerrickWood/kraken2/archive/refs/tags/v2.1.3.tar.gz
    tar -xzf v2.1.3.tar.gz
    cd kraken2-2.1.3
    bash install_kraken2.sh /usr/local/bin/
    cd /opt
    rm -rf kraken2-2.1.3 v2.1.3.tar.gz

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH

%runscript
    exec kraken2 "$@"
