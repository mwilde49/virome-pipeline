Bootstrap: docker
From: ubuntu:22.04

%labels
    tool    STAR
    version 2.7.11b
    purpose Align reads to host genome; unmapped reads go to viral classification

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y --no-install-recommends \
        wget \
        && rm -rf /var/lib/apt/lists/*

    cd /opt
    wget -q https://github.com/alexdobin/STAR/releases/download/2.7.11b/STAR_2.7.11b.zip
    unzip STAR_2.7.11b.zip
    cp STAR_2.7.11b/Linux_x86_64_static/STAR /usr/local/bin/
    rm -rf STAR_2.7.11b STAR_2.7.11b.zip

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH

%runscript
    exec STAR "$@"
