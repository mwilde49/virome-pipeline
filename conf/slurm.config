/*
 * conf/slurm.config — SLURM executor settings for Juno HPC
 */

process {
    executor     = 'slurm'
    queue        = 'normal'
    clusterOptions = '--account=tprice'

    // Load apptainer and emit SLURM job ID for monitoring
    beforeScript = 'module load apptainer && echo "SLURM_JOB_ID: $SLURM_JOB_ID"'
}

executor {
    name           = 'slurm'
    queueSize      = 50       // max concurrent jobs submitted at once
    pollInterval   = '30 sec'
    submitRateLimit = '10/1min'
}
