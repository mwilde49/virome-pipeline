/*
 * conf/base.config — per-process resource allocations
 */

process {

    // Defaults
    cpus        = 2
    memory      = '8.GB'
    time        = '4.h'
    stageInMode = 'copy'

    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    withName: 'FASTQC' {
        cpus   = 4
        memory = '8.GB'
        time   = '2.h'
    }

    withName: 'TRIMMOMATIC' {
        cpus   = 8
        memory = '16.GB'
        time   = '12.h'  // donor1-L5 has 174M reads
    }

    withName: 'STAR_HOST_REMOVAL' {
        cpus        = 16
        memory      = '64.GB'
        time        = '24.h'  // donor1-L5 has 174M reads
        stageInMode = 'symlink'  // STAR index is 33 GB — symlink, not copy
    }

    withName: 'KRAKEN2_CLASSIFY' {
        cpus        = 16
        memory      = { 64.GB * task.attempt }  // scale on OOM retry
        time        = '12.h'
        stageInMode = 'symlink'  // viral DB is 1.1 GB; symlink + autoMounts, no copy
    }

    withName: 'KRAKEN2_CLASSIFY_DB2' {
        cpus        = 16
        memory      = { 110.GB * task.attempt }  // PlusPF hash.k2d is 87 GB
        time        = '12.h'
        stageInMode = 'symlink'  // PlusPF DB is 87 GB — must not copy
    }

    withName: 'BRACKEN' {
        cpus        = 4
        memory      = '16.GB'
        time        = '2.h'
        stageInMode = 'symlink'  // DB shared with KRAKEN2_CLASSIFY; avoid redundant copy
    }

    withName: 'BRACKEN_DB2' {
        cpus        = 4
        memory      = '16.GB'
        time        = '2.h'
        stageInMode = 'symlink'
    }

    withName: 'KRAKEN2_FILTER' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }

    withName: 'AGGREGATE' {
        cpus   = 2
        memory = '8.GB'
        time   = '1.h'
    }

    withName: 'MULTIQC' {
        cpus   = 2
        memory = '8.GB'
        time   = '1.h'
    }

    withName: 'REPORT' {
        cpus   = 2
        memory = '8.GB'
        time   = '1.h'
    }

    withName: 'EXTRACT_KRAKEN2_READS' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }

    withName: 'BLAST_VERIFY' {
        cpus   = 8
        memory = '32.GB'   // nt database is large; keep in memory for speed
        time   = '4.h'
        stageInMode = 'symlink'  // blast_db_dir can be 100+ GB; never copy
    }

    withName: 'BLAST_ANALYZE' {
        cpus   = 4
        memory = '8.GB'
        time   = '1.h'
    }
}
