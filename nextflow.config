/*
 * Virome Pipeline — nextflow.config
 * Global parameters and profile definitions.
 */

manifest {
    name        = 'virome'
    description = 'Systematic profiling of the human DRG virome from bulk RNA-seq data'
    version     = '1.4.0'
    nextflowVersion = '>=23.04.0'
}

// ---------------------------------------------------------------------------
// Default parameters (all overridable via config.yaml or --param CLI flags)
// ---------------------------------------------------------------------------
params {

    // --- Required ---
    samplesheet = null
    outdir      = null

    // --- References ---
    star_index   = null   // path to pre-built STAR index (GRCh38)
    kraken2_db   = null   // path to Kraken2 viral database

    // --- Trimmomatic ---
    adapters         = "${projectDir}/assets/NexteraPE-PE.fa"
    trim_leading     = 3
    trim_trailing    = 3
    trim_slidingwindow = '4:15'
    trim_minlen      = 36
    trim_headcrop    = 0

    // --- Host removal (STAR) ---
    star_extra_args  = ''

    // --- Kraken2 ---
    kraken2_confidence  = 0.1
    kraken2_extra_args  = ''

    // --- Bracken ---
    bracken_read_length = 150   // match your sequencing read length (50/75/100/150/200/250/300)
    bracken_level       = 'S'   // taxonomic level: S=species, G=genus
    bracken_threshold   = 10    // min reads required to re-estimate abundance

    // --- Filtering ---
    min_reads_per_taxon = 5    // minimum read count to retain a taxon per sample
    artifact_list       = "${projectDir}/assets/artifact_taxa.tsv"  // set to null to disable
    taxon_remap         = "${projectDir}/assets/taxon_remap.tsv"    // set to null to disable

    // --- Dual-database comparison (optional) ---
    // Set kraken2_db2 to a PlusPF or standard Kraken2 DB path to run a parallel
    // classification branch. Produces a consensus matrix (taxa detected in both
    // databases) and a false-positive candidate list (taxa in viral-only only).
    // Leave null for single-DB mode (default behavior, no change to outputs).
    kraken2_db2         = null

    // --- Containers ---
    container_dir = '/groups/tprice/pipelines/containers/virome'

    // --- PathSeq (optional validation) ---
    run_pathseq      = false
    pathseq_microbe_bwa_image = null
    pathseq_microbe_fasta     = null
    pathseq_taxonomy          = null

    // --- MultiQC ---
    multiqc_config   = null
    multiqc_title    = 'Virome Pipeline QC Report'
}

// ---------------------------------------------------------------------------
// Configuration profiles
// ---------------------------------------------------------------------------
profiles {

    slurm {
        includeConfig 'conf/slurm.config'
        workDir = "/scratch/juno/${System.getenv('USER')}/nf_work"
    }

    standard {
        process.executor = 'local'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ---------------------------------------------------------------------------
// Base resource defaults (overridden per-process in conf/base.config)
// ---------------------------------------------------------------------------
includeConfig 'conf/base.config'

// ---------------------------------------------------------------------------
// Apptainer settings
// ---------------------------------------------------------------------------
apptainer {
    enabled    = true
    autoMounts = true
    runOptions = '--cleanenv'
}

// ---------------------------------------------------------------------------
// Execution reports
// ---------------------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.tsv"
    overwrite = true
    fields    = 'task_id,process,tag,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar,vol_ctxt,inv_ctxt'
}
