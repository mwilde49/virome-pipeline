/*
 * Virome Pipeline — nextflow.config
 * Global parameters and profile definitions.
 */

manifest {
    name        = 'virome'
    description = 'Systematic profiling of the human DRG virome from bulk RNA-seq data'
    version     = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

// ---------------------------------------------------------------------------
// Default parameters (all overridable via config.yaml or --param CLI flags)
// ---------------------------------------------------------------------------
params {

    // --- Required ---
    samplesheet = null
    outdir      = null

    // --- References ---
    star_index   = null   // path to pre-built STAR index (GRCh38)
    kraken2_db   = null   // path to Kraken2 viral database

    // --- Trimmomatic ---
    adapters         = "${projectDir}/assets/NexteraPE-PE.fa"
    trim_leading     = 3
    trim_trailing    = 3
    trim_slidingwindow = '4:15'
    trim_minlen      = 36
    trim_headcrop    = 0

    // --- Host removal (STAR) ---
    star_extra_args  = ''

    // --- Kraken2 ---
    kraken2_confidence  = 0.1
    kraken2_extra_args  = ''

    // --- Filtering ---
    min_reads_per_taxon = 5    // minimum read count to retain a taxon per sample

    // --- Containers ---
    container_dir = '/groups/tprice/pipelines/containers/virome'

    // --- PathSeq (optional validation) ---
    run_pathseq      = false
    pathseq_microbe_bwa_image = null
    pathseq_microbe_fasta     = null
    pathseq_taxonomy          = null

    // --- MultiQC ---
    multiqc_config   = null
    multiqc_title    = 'Virome Pipeline QC Report'
}

// ---------------------------------------------------------------------------
// Configuration profiles
// ---------------------------------------------------------------------------
profiles {

    slurm {
        includeConfig 'conf/slurm.config'
    }

    standard {
        process.executor = 'local'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ---------------------------------------------------------------------------
// Base resource defaults (overridden per-process in conf/base.config)
// ---------------------------------------------------------------------------
includeConfig 'conf/base.config'

// ---------------------------------------------------------------------------
// Apptainer settings
// ---------------------------------------------------------------------------
apptainer {
    enabled    = true
    autoMounts = true
    runOptions = '--cleanenv'
}

// ---------------------------------------------------------------------------
// Execution reports
// ---------------------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}
